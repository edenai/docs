{ // Ensure that tests/generated files are included in the explorer and search results
  "explorer.excludeGitIgnore": false,
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/htmlcov": true,
    "coverage.xml": true,
    ".coverage": true,
    ".venv": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/htmlcov": true,
    "coverage.xml": true,
    ".coverage": true,
    ".venv": true
  },
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests",
    "-v"
  ]
}
